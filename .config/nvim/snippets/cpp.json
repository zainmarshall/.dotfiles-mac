      "using vvpll = V<vpll>;",
      "template <typename T, size_t SZ>",
      "using AR = array<T, SZ>;",
      "template <typename T, typename Container = vector<T>, typename Compare = less<T>>",
      "using pqu = priority_queue<T, Container, Compare>;",
      "template <typename T>",
      "using qu = queue<T>;",
      "#define mp make_pair",
      "#define f first",
      "#define s second",
      "#define all(x) begin(x), end(x)",
