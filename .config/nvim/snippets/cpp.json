      "#define no cout << \"NO\\n\"",
      "#define nl cout << \"\\n\"",
      "",
      "template<typename T>",
      "int lwb(V<T>& a, const T& b) { return int(lb(all(a),b)-begin(a)); } ",
      "template<typename T>",
      "int upb(V<T>& a, const T& b) { return int(ub(all(a),b)-begin(a)); }",
      "",
      "template<typename T1, typename T2>",
      "istream& operator>>(istream& is, pair<T1, T2>& p) { is >> p.f >> p.s; return is; }",
